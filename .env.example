# AWS Serverless SOAR Environment Variables
# Note: In production, these are injected by AWS Lambda environment configuration (via Terraform).
# This file is provided for local development and documentation purposes.

# Core Configuration
LOG_LEVEL=INFO
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:security-alerts
EXFILTRATION_THRESHOLD=10000000000
ISOLATION_SG_ID=sg-0123456789abcdef0

# Step Functions Queue Processor
STEP_FUNCTION_ARN=arn:aws:states:us-east-1:123456789012:stateMachine:soar-incident-response
DLQ_URL=https://sqs.us-east-1.amazonaws.com/123456789012/soar-dlq

# Cross-Account Role Assumptions
CROSS_ACCOUNT_EXTERNAL_ID=soar-cross-account-2024
DEV_ACCOUNT_ID=111111111111
DEV_SOAR_ROLE_NAME=soar-cross-account-responder
STAGING_ACCOUNT_ID=222222222222
STAGING_SOAR_ROLE_NAME=soar-cross-account-responder
PROD_ACCOUNT_ID=333333333333
PROD_SOAR_ROLE_NAME=soar-cross-account-responder

# Third-Party Integrations
SIEM_TYPE=splunk
SPLUNK_INDEX=security
JIRA_URL=https://your-domain.atlassian.net
JIRA_USER=security-bot@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=SEC
JIRA_WATCHERS=user1@example.com,user2@example.com
VIRUSTOTAL_API_KEY=your-vt-api-key
ABUSEIPDB_API_KEY=your-abuseipdb-api-key
